<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_pos_sales_employee_report_form" model="ir.ui.view">
        <field name="name">pos.sales.employee.report.form</field>
        <field name="model">pos.sales.employee.report</field>
        <field name="arch" type="xml">
            <form string="POS Sales Employee Report">
                <h1 style="color:purple;font-weight:1000;text-align:center;">POS Sales Employee Report</h1>
                <header>
                    <button name="action_generate_report" string="Generate Report"
                            type="object" class="btn-primary"/>
                    <button name="action_export_excel" string="Export Excel"
                            type="object" class="btn-success"/>
                    <button name="action_print_pdf" string="Print PDF"
                            type="object" class="btn-secondary"/>
                    <button name="action_to_reset" type="object"
                                string="Reset" class="btn-danger"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="company_id" options="{'no_create': True, 'no_open': True, 'no_edit':True}"/>
                            <field name="employee_id" options="{'no_create': True, 'no_open': True, 'no_edit':True}"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Summary">
                            <field name="report_line_ids" readonly="1">
                                <tree editable="bottom">
                                    <field name="category_id"
                                           options="{'no_create': True, 'no_open': True, 'no_edit':True}"/>
                                    <field name="employee_id"
                                           options="{'no_create': True, 'no_open': True, 'no_edit':True}"/>
                                    <field name="job_position_id"
                                           options="{'no_create': True, 'no_open': True, 'no_edit':True}"/>
                                    <field name="quantity" sum="Quantity"/>
                                    <field name="total_amount" sum="Total Amount"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="sale_person_report_action" model="ir.actions.act_window">
        <field name="name">Sale Person Report</field>
        <field name="res_model">pos.sales.employee.report</field>
        <field name="view_mode">form</field>
    </record>

    <menuitem id="sale_person_report_menu"
              name="Sales Employee Report"
              parent="sale.menu_sale_report"
              action="nhcl_customizations.sale_person_report_action"
              sequence="10"/>
</odoo>