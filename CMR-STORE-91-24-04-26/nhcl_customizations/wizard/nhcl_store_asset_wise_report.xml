<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="nhcl_store_asset_report_form" model="ir.ui.view">
        <field name="name">Asset Report Form</field>
        <field name="model">nhcl.store.asset.report</field>
        <field name="arch" type="xml">
            <form string="Store Asset Report" create="0">
                <h1 style="color:black;font-weight:1000;text-align:center;">Store Wise Asset Report</h1>
                <sheet>
                    <header>
                        <button name="nhcl_store_asset_report" type="object"
                                string="Submit" class="btn-primary"/>
                        <button name="action_to_reset" type="object"
                                string="Reset" class="btn-secondary"/>
                        <button name="get_excel_sheet" type="object"
                                string="Excel" class="btn-success"/>
                    </header>
                    <group name="store_Asset_report" style="border: 2px solid #990099; padding: 10px;">
                        <group name="store_Asset_report_group">
                            <field name="nhcl_company_id"/>
                        </group>
                        <group name="store_Asset_report_date_details">
                            <group>
                                <field name="from_date" required="1" widget="daterange"
                                       options="{'to_date_field': 'to_date'}"/>
                                <field name="to_date" required="1"/>
                            </group>

                        </group>
                    </group>
                    <notebook>
                        <page string="Asset Lines">
                            <field name="nhcl_store_asset_report_ids" readonly="1" forsesave="1">
                                <tree create="0" delete="0" editable="bottom">
                                    <field name="nhcl_company_id"/>
                                    <field name="asset_name"/>
                                    <field name="global_amount" sum="net_total"/>
                                </tree>
                            </field>

                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


</odoo>

