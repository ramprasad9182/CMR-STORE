<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_delivery_import_wizard_form" model="ir.ui.view">
    <field name="name">delivery.import.wizard.form</field>
    <field name="model">delivery.import.wizard</field>
    <field name="arch" type="xml">
        <form string="Import Delivery">

            <group>
                <field name="picking_id" invisible="1"/>
                <field name="file" filename="filename"/>
                <field name="filename" invisible="1"/>
            </group>

            <footer>
                <button name="action_import_barcodes"
                        type="object"
                        string="Import"
                        class="btn-primary"/>
                <button string="Cancel" class="btn-secondary" special="cancel"/>
            </footer>

        </form>
    </field>
</record>
</odoo>