<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--    Inheriting form view of hr employee-->
    <record id="view_employee_form" model="ir.ui.view">
        <field name="name">hr.employee.view.form.inherit.pos.discount.manager
        </field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='job_id']" position="after">
                <field name="limited_discount"/>
                <field name="store_manager"/>
            </xpath>
        </field>
    </record>

    <record id="hr_employee_pos_access_view" model="ir.ui.view">
        <field name="name">hr.employee.view.pos.access.resume</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='hr_settings']" position="after">
                <page string="POS Discount Access" name="point_of_sale" invisible="store_manager == 0">
                    <group name="pos_manager_access">
                        <field name="allow_selected_lines_discount"/>
                        <field name="allow_global_discount"/>
                        <field name="allow_amount_discount"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
