<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

<!--    <t t-name="pos_discount.DiscountButton">-->
    <t t-name="DiscountButton" t-inherit="pos_discount.DiscountButton" t-inherit-mode="extension">
        <span position="replace">
            <span t-if="this.pos.get_cashier().allow_global_discount"
                  class="control-button js_discount btn btn-light rounded-0 fw-bolder"
                  t-on-click="() => this.click()">
                <i class="fa fa-tag me-1"></i>
                <span> </span>
                <span>Global Discount</span>
            </span>
        </span>
    </t>

</templates>
