<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_cf_inventory_count_tree" model="ir.ui.view">
        <field name="name">cf.inventory.count.tree</field>
        <field name="model">cf.inventory.count</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="date"/>
                <field name="company_id"/>
            </tree>
        </field>
    </record>

    <record id="view_cf_inventory_count_form" model="ir.ui.view">
        <field name="name">cf.inventory.count.form</field>
        <field name="model">cf.inventory.count</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="company_id" options='{"no_open": True, "no_create": True,"no_edit": True}' readonly="1"/>
                            <field name="requester_id" readonly="1"
                                   options='{"no_open": True, "no_create": True,"no_edit": True}'/>
                        </group>
                        <group>
                            <field name="upload_file" filename="upload_filename"/>
                            <field name="upload_filename" invisible="1"/>
                            <button name="action_import_excel"
                                    type="object"
                                    string="Import Excel"
                                    class="btn-primary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lines">
                            <field name="line_ids">
                                <tree editable="bottom" delete="0" decoration-danger="diff &lt; 0">
                                    <field name="asset_id" options='{"no_open": True, "no_create": True,"no_edit": True}'/>
                                    <field name="floor"/>
                                    <field name="family_id" readonly="1" force_save="1"/>
                                    <field name="cat_id" readonly="1" force_save="1"/>
                                    <field name="class_id" readonly="1" force_save="1"/>
                                    <field name="brick_id" readonly="1" force_save="1"/>
                                    <field name="product_tmpl_id"/>
                                    <field name="global_count"/>
                                    <field name="soh" readonly="1" force_save="1"/>
                                    <field name="diff" readonly="1" force_save="1"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="cmr_cf_asset_master_tree_view" model="ir.ui.view">
        <field name="name">cf.asset.master.tree></field>
        <field name="model">cf.asset.master</field>
        <field name="arch" type="xml">
            <tree delete="0" duplicate="0" import="0">
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="cmr_cf_asset_master_form_view" model="ir.ui.view">
        <field name="name">cf.asset.master.form></field>
        <field name="model">cf.asset.master</field>
        <field name="arch" type="xml">
            <form delete="0" duplicate="0">
                <sheet>
                    <group>
                        <field name="name" required="1"/>
                        <field name="code"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="cmr_cf_asset_master_action" model="ir.actions.act_window">
        <field name="name">Asset Master</field>
        <field name="res_model">cf.asset.master</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="cmr_asset_master"
              name="Asset Master"
              parent="stock.menu_warehouse_config"
              action="nhcl_customizations.cmr_cf_asset_master_action"
              sequence="100"/>

    <record id="action_cf_inventory_count" model="ir.actions.act_window">
        <field name="name">Global Count</field>
        <field name="res_model">cf.inventory.count</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_cf_inventory"
              name="Global Count"
              parent="stock.menu_stock_transfers"
              action="action_cf_inventory_count"
              sequence="21"/>
</odoo>