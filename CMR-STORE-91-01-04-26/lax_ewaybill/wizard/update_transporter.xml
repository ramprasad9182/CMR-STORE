<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="update_transpoter_wizard" model="ir.ui.view">
            <field name="name">update.transpoter</field>
            <field name="model">update.transpoter</field>
            <field name="arch" type="xml">
                <form>
                    <group>
                        <field name="transporter_gst" required="1" readonly="0"/>
                    </group>
                    <footer>
                        <button class="btn-primary" name="update_transporter" string="Submit" type="object"/>
                        <button class="btn-primary" special="cancel" string="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>