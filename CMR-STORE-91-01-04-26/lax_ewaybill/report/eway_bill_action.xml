<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="paperformat_eway_bill" model="report.paperformat">
        <field name="name">E-Way Bill Paper Format</field>
        <field name="default" eval="True" />
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">7</field>
        <field name="margin_bottom">3</field>
        <field name="margin_left">3</field>
        <field name="margin_right">3</field>
        <field name="header_line" eval="False" />
        <field name="header_spacing">19</field>
        <field name="dpi">100</field>
    </record>

    <record id="action_eway_bill_report" model="ir.actions.report">
        <field name="name">E-Way Bill Report</field>
        <field name="model">eway.bill.details</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">lax_ewaybill.report_eway_bill_template</field>
        <field name="report_file">lax_ewaybill.report_eway_bill_template</field>
        <field name="print_report_name">(object.name)</field>
        <field name="binding_model_id" ref="lax_ewaybill.model_eway_bill_details"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="lax_ewaybill.paperformat_eway_bill" />
    </record>
</odoo>