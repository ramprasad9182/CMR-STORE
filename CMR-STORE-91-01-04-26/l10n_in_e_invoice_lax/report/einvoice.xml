<odoo>
<template id="report_invoice_document_inherit" inherit_id="account.report_invoice_document">
    <xpath expr="//div[@id='right-elements']" position="after">
        <div id="right-elements" class="row">

            <div class="col-6 text-start">
                <div class="row">
                    <div class="col-20">
                        <strong>IRN Number:</strong> <span t-esc="o.irn_no" /><br/>
                        <strong>Acknowledgement Number:</strong> <span t-esc="o.ack_no" /><br/>
                        <strong>Acknowledgement Date:</strong> <span t-esc="o.ack_date" />
                    </div>
                    <div class="col-8 ps-5 text-center">
                        <strong>QR Code:</strong>
                        <br/>
                        <img t-att-src="'/report/barcode/?type=QR&amp;value=%s&amp;width=200&amp;height=200' % o.signed_invoice" 
                             width="150" height="150"/>
                    </div>
                </div>
            </div>
        </div>
    </xpath>
    <xpath expr="//div[@name='due_date']" position="after">
        <div class="col-6 text-start">
            <strong>EWB Number:</strong> <span t-esc="o.ewb_no" /><br/>
            <strong>EWB Date:</strong> <span t-esc="o.ewb_date" />
        </div>
    </xpath>
</template>


</odoo>

 
