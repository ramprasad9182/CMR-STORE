<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="TicketScreenDeleteAllOrder" t-inherit="point_of_sale.TicketScreen" t-inherit-mode="extension">
        <xpath expr="//div[@t-if='shouldShowPageControls()']" position="after">
            <button t-if="this.show_delete_button"
                    class="highlight btn btn-lg btn-primary"
                    t-on-click="() => this.onClickDeleteSelectedOrders()">Delete</button>
        </xpath>
        <xpath expr="//div[hasclass('header-row')]//div[hasclass('col', 'wide')][2]" position="after">
            <div class="col p-2">Terminal ID</div>
        </xpath>
        <xpath expr="//div[hasclass('order-row')]//div[hasclass('col', 'wide')][3]" position="before">
            <div class="col p-2">
                <div><t t-esc="order.pos.config.name"></t></div>
            </div>
        </xpath>
        <xpath expr="//div[hasclass('header-row')]//div[hasclass('col', 'wide')]" position="before">
            <input t-if="this._state.ui.filter == 'ONGOING'"
                   type="checkbox" t-att-checked="this.select_all_ongoing_order_in_ticket_screen"
                   t-on-click="onClickAllSelectOrders"
                   class="col very-narrow p-2 rounded-2"/>
        </xpath>
        <xpath expr="//div[hasclass('order-row')]//div[hasclass('col', 'wide')]" position="before">
            <input t-if="this._state.ui.filter == 'ONGOING'"
                   type="checkbox" t-att-checked="order.select_order_in_ticket_screen"
                   t-att-disabled="getStatus(order) != 'Ongoing'"
                   t-on-click="() => this.onClickSelectOrder(order)"
                   class="col very-narrow p-2 rounded-2"/>
        </xpath>
    </t>
</templates>
