<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="nhcl_sale_daily_report" model="ir.actions.act_window">
        <field name="name">Daily Sale Report</field>
        <field name="res_model">nhcl.daily.sale.report</field>
        <field name="view_mode">form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>

        <record id="empty_page" model="ir.actions.client">
        <field name="name">Empty</field>
        <field name="tag">empty_report</field>
    </record>

    <menuitem id="hour_report_menu_root"
              name="MIS Reports/Dashboards"
              action="empty_page"/>


    <menuitem id="reporting_status"
              name="Reports"
              parent="hour_report_menu_root"
              sequence="1"/>


    <menuitem id="reporting_status_sale_daily"
              name="Daily Sale DSD Report"
              parent="hour_report_menu_root"
              action="nhcl_customizations.nhcl_sale_daily_report"
              sequence="2"/>
</odoo>