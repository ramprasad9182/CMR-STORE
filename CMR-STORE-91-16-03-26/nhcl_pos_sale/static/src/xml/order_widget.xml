<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="OrderWidget" t-inherit="point_of_sale.OrderWidget" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('order-summary')]" position="replace">
            <div t-if="props.total or props.tax" class="order-summary w-100 py-2 px-3 bg-100 fw-bolder fs-2 lh-sm">
                <div class="row">
                    <div class="col-6">
                        Total Quantity: <span t-esc="this.get_total_quantity()"/>
                    </div>
                    <div class="col-6 text-end">
                        Total:
                        <span t-esc="props.total" class="total"/>
                        <div t-if="props.tax" class="fs-6 text-muted subentry">
                            Taxes: <span t-esc="props.tax" class="tax"/>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
        <xpath expr="//span[hasclass('total')]" position="replace">
<!--            <span t-esc="props.total" class="total"/>-->
            <t t-set="pos_order" t-value="this.env.services.pos.get_order()"/>
            <t t-set="custom_total" t-value="pos_order.get_total_with_tax() - pos_order.credit_note_amount"/>
            <t t-if="custom_total &lt; 0">
                <span t-esc="env.utils.formatCurrency(0.00)" class="total"/>
            </t>
            <t t-else="">
                <span t-esc="env.utils.formatCurrency(custom_total)" class="total"/>
            </t>
        </xpath>
	</t>
</templates>
