                                        <span t-esc="state.total.liveStore">0</span>
                                        <i class="fa fa-chevron-down" style="padding-left:20px; font-size:10px;"></i>
                                    </div>
                                </td>
                                <td class="td">
                                    <div class="info-title">
                                        Master Data Processed Today
                                    </div>
                                    <div><br/></div>
                                    <div class="info-number">
                                        <span t-esc="state.total.masterProcessedToday">0</span>
                                    </div>
                                </td>
                                <td class="td">
                                    <div class="info-title">
                                        Master Data Not Processed Ho to All Stores
                                    </div>
                                    <div class="info-number">
                                        <span t-esc="state.total.masterNotProcessed">0</span>
                                    </div>
                                </td>
                            </tr>
                        </table>
                    </div>
