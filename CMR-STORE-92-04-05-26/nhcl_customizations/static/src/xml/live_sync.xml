                                    </div>
                                </td>
                            </tr>
                         </table>
                    </div>
                </t>
                <t t-if="state.selected === 9">
                    <div>
                         <table class="styled-table">
                            <tr class="master-tab">
                                <td class="td">
                                    <div class="info-title">
                                        Total Configured Stores
                                    </div>
                                    <div class="info-number clickable-div"
