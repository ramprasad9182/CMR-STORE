<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="ir_cron_update_loyalty_is_active" model="ir.cron">
        <field name="name">Update Loyalty Program Is Active</field>
        <field name="model_id" ref="loyalty.model_loyalty_program"/>
        <field name="state">code</field>
        <field name="code">model.cron_update_is_active()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_auto_cancel_old_sale_orders" model="ir.cron">
        <field name="name">Auto Cancel Old Sale Orders</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="state">code</field>
        <field name="code">model.auto_cancel_old_sale_orders()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="nextcall" eval="(DateTime.now().replace(hour=11, minute=0, second=0))"/>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_pending_data_import_orders" model="ir.cron">
            <field name="name">OB GRC's Validate</field>
            <field name="model_id" ref="model_stock_picking"/>
            <field name="state">code</field>
            <field name="code">model.auto_validate_ob_grc()</field>
            <field name="interval_type">minutes</field>
            <field name="interval_number">10</field>
            <field name="numbercall">-1</field>
            <field name="active">False</field>
        </record>
</odoo>
