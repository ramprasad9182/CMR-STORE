<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="nhcl_terminal_wise_mop_report_form" model="ir.ui.view">
        <field name="name">Terminal wise MOP Report Form</field>
        <field name="model">nhcl.teminal.mop.report</field>
        <field name="arch" type="xml">
            <form string="Terminal Wise MOP Report" create="0">
                <h1 style="color:black;text-align:center;">Terminal Wise MOP Report
                </h1>
                <sheet>

                    <header>
                        <button name="get_terminal_wise_mop_report" type="object"
                                string="Submit" />
                        <button name="action_to_reset" type="object"
                                string="Reset" />
                        <button name="action_mop_detailed_report" type="object"
                                string="View Detailed Report" />

                    </header>
                    <group name="terminal_mop_report" style="border: 2px solid #990099; padding: 10px;">
                        <group name="mop_report_group">
                            <field name="nhcl_company_id" required="1"
                                   placeholder="Select Company"/>
                            <field name="config_id"/>
                            <field name="payment_method"/>
                        </group>
                        <group name="mop_report_date_details">
                            <group>
                                <field name="from_date" required="1" widget="daterange"
                                       options="{'to_date_field': 'to_date'}"/>
                                <field name="to_date" required="1"/>
                            </group>

                        </group>
                    </group>
                    <notebook>
                        <page string="mopDetailed Report">
                            <group>
                                <group>
                                    <field name="total_cash"/>
                                    <field name="total_hdfc"/>
                                    <field name="total_paytm"/>
                                    <field name="total_bajaj"/>
                                    <field name="total_cheque"/>
                                    <field name="total_credit_note_settlement"/>
                                    <field name="total_credit_note_issues"/>
                                </group>
                                <group>
                                    <field name="total_axis"/>
                                    <field name="total_kotak"/>
                                    <field name="total_sbi"/>
                                    <field name="total_mobikwik"/>
                                    <field name="total_gift_voucher"/>
                                    <field name="grand_total"/>
                                </group>
                            </group>
                            <field name="nhcl_terminal_wise_mop_report_ids" readonly="1" forsesave="1">
                                <tree create="0" delete="0" editable="bottom" limit="1000000">
                                    <field name="nhcl_company_id"/>
                                    <field name="config_id"/>
                                    <field name="cash" sum="Total"/>
                                    <field name="axis" sum="Total"/>
                                    <field name="hdfc" sum="Total"/>
                                    <field name="kotak" sum="Total"/>
                                    <field name="paytm" sum="Total"/>
                                    <field name="sbi" sum="Total"/>
                                    <field name="bajaj" sum="Total"/>
                                    <field name="mobikwik" sum="Total"/>
                                    <field name="cheque" sum="Total"/>
                                    <field name="gift_voucher" sum="Total"/>
                                    <field name="credit_note_settlement" sum="Total"/>
                                    <field name="credit_note_issues" sum="Total"/>
                                    <field name="grand_total" sum="Total"/>
                                </tree>
                            </field>

                        </page>
                    </notebook>
                </sheet>

            </form>
        </field>
    </record>

    <record id="view_nhcl_terminal_wise_mop_report_line_tree" model="ir.ui.view">
        <field name="name">Terminal wise MOP Report Tree</field>
        <field name="model">nhcl.teminal.mop.report.line</field>
        <field name="arch" type="xml">
            <tree>
                <field name="nhcl_company_id"/>
                <field name="config_id"/>
                <field name="cash" sum="Total"/>
                <field name="axis" sum="Total"/>
                <field name="hdfc" sum="Total"/>
                <field name="kotak" sum="Total"/>
                <field name="paytm" sum="Total"/>
                <field name="sbi" sum="Total"/>
                <field name="bajaj" sum="Total"/>
                <field name="mobikwik" sum="Total"/>
                <field name="cheque" sum="Total"/>
                <field name="gift_voucher" sum="Total"/>
                <field name="credit_note_settlement" sum="Total"/>
                <field name="credit_note_issues" sum="Total"/>
                <field name="grand_total" sum="Total"/>
            </tree>
        </field>
    </record>
    <record id="view_nhcl_terminal_wise_mop_line_pivot" model="ir.ui.view">
        <field name="name">Terminal wise MOP Report Pivot</field>
        <field name="model">nhcl.teminal.mop.report.line</field>
        <field name="arch" type="xml">
            <pivot string="Terminal wise MOP Analysis">

                <!-- ROW FIELDS (Group By) -->
                <field name="nhcl_company_id" type="row"/>
                <field name="config_id" type="row"/>
                <!-- MEASURES -->
                <field name="cash" type="measure"/>
                <field name="axis" type="measure"/>
                <field name="hdfc" type="measure"/>
                <field name="kotak" type="measure"/>
                <field name="paytm" type="measure"/>
                <field name="sbi" type="measure"/>
                <field name="bajaj" type="measure"/>
                <field name="mobikwik" type="measure"/>
                <field name="cheque" type="measure"/>
                <field name="gift_voucher" type="measure"/>
                <field name="credit_note_settlement" type="measure"/>
                <field name="credit_note_issues" type="measure"/>
                <field name="grand_total" type="measure"/>

            </pivot>
        </field>
    </record>
</odoo>