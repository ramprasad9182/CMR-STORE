<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="nhcl_pos_hour_report_form" model="ir.ui.view">
        <field name="name">Pos Hour Report Form</field>
        <field name="model">nhcl.pos.hour.report</field>
        <field name="arch" type="xml">
            <form string="Bill Wise Sale Report" create="0">
                <h1 style="color:black;text-align:center;">Bill Wise Sale Report
                </h1>
                <sheet>

                    <header>
                        <button name="get_pos_order_hour_report" type="object"
                                string="Submit" />
                        <button name="action_to_reset" type="object"
                                string="Reset" />
                        <button name="action_view_pos_hour_lines" type="object"
                                string="View Detailed Report"/>

                    </header>
                    <group name="pos_hour_report" style="border: 2px solid #990099; padding: 10px;">
                        <group name="pos_hour_report_group">
                            <field name="nhcl_company_id" required="1"
                                   placeholder="Select Company"/>
                            <field name="name" invisible="1"/>
                            <field name="config_id"/>
                        </group>
                        <group name="pos_hour_report_date_details">
                            <group>
                                <field name="from_date" required="1" widget="daterange"
                                       options="{'to_date_field': 'to_date'}"/>
                                <field name="to_date" required="1"/>
                            </group>

                        </group>
                    </group>
                    <notebook>
                        <page string="POS Order Report">
                            <group>
                                <group>
                                    <field name="total_order_quantity"/>
                                    <field name="total_in_amount_total"/>
                                    <field name="total_discount_amount"/>
                                </group>
                                <group>
                                    <field name="total_amount_total"/>
                                    <field name="total_tax_amount"/>
                                    <field name="total_amount_payment"/>
                                </group>
                            </group>
                            <field name="nhcl_pos_hour_report_ids" readonly="1" forsesave="1">
                                <tree create="0" delete="0" editable="bottom" limit="1000000">
                                    <field name="nhcl_company_id"/>
                                    <field name="config_id"/>
                                    <field name="nhcl_order_ref"/>
                                    <field name="nhcl_bill_receipt_no"/>
                                    <field name="nhcl_date_order"/>
                                    <field name="nhcl_order_quantity" sum="Total"/>
                                    <field name="nhcl_amount_total" sum="Total"/>
                                    <field name="nhcl_in_amount_total" sum="Total"/>
                                    <field name="nhcl_tax_amount" sum="Total"/>
                                    <field name="nhcl_discount" sum="Total"/>
                                    <field name="nhcl_amount_payment" sum="Total"/>
                                </tree>
                            </field>

                        </page>
                    </notebook>
                </sheet>

            </form>
        </field>
    </record>

    <record id="view_nhcl_pos_hour_report_line_tree" model="ir.ui.view">
        <field name="name">nhcl.pos.hour.report.line.tree</field>
        <field name="model">nhcl.pos.hour.report.line</field>
        <field name="arch" type="xml">
            <tree limit="1000000">
                <field name="nhcl_company_id"/>
                <field name="config_id"/>
                <field name="nhcl_order_ref"/>
                <field name="nhcl_bill_receipt_no"/>
                <field name="nhcl_date_order"/>
                <field name="nhcl_order_quantity" sum="Total"/>
                <field name="nhcl_amount_total" sum="Total"/>
                <field name="nhcl_in_amount_total" sum="Total"/>
                <field name="nhcl_amount_payment" sum="Total"/>
                <field name="nhcl_tax_amount" sum="Total"/>
                <field name="nhcl_discount" sum="Total"/>
            </tree>
        </field>
    </record>
    <record id="view_nhcl_pos_hour_report_line_pivot" model="ir.ui.view">
        <field name="name">nhcl.pos.hour.report.line.pivot</field>
        <field name="model">nhcl.pos.hour.report.line</field>
        <field name="arch" type="xml">
            <pivot string="POS Hour Report Analysis">
                <field name="nhcl_company_id" type="row"/>
                <field name="config_id" type="row"/>
                <field name="nhcl_date_order" interval="day" type="col"/>
                <field name="nhcl_amount_total" type="measure"/>
                <field name="nhcl_in_amount_total" type="measure"/>
                <field name="nhcl_amount_payment" type="measure"/>
                <field name="nhcl_order_quantity" type="measure"/>
            </pivot>
        </field>
    </record>
</odoo>