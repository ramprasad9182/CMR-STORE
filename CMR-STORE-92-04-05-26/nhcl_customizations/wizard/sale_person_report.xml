<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_pos_sales_employee_report_form" model="ir.ui.view">
        <field name="name">pos.sales.employee.report.form</field>
        <field name="model">pos.sales.employee.report</field>
        <field name="arch" type="xml">
            <form string="POS Sales Employee Report">
                <h1 style="color:black;text-align:center;">POS Sales Employee Report</h1>
                <header>
                    <button name="action_generate_report" string="Generate Report"
                            type="object"/>
                    <button name="action_view_sale_employee_detailed_report" string="View Detailed Report"
                            type="object"/>
                    <!--                    <button name="action_print_pdf" string="Print PDF"-->
                    <!--                            type="object" class="btn-secondary"/>-->
                    <button name="action_to_reset" type="object"
                            string="Reset"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="company_id" required="1" options="{'no_create': True, 'no_open': True, 'no_edit':True}"/>
                            <field name="employee_id" options="{'no_create': True, 'no_open': True, 'no_edit':True}"/>
                            <field name="employee_code"/>
                        </group>
                        <group>
                            <field name="from_date"/>
                            <field name="to_date"/>
                            <field name="family"/>
                                <field name="category"/>
                                <field name="nhcl_class"/>
                                <field name="brick"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Summary">
                            <group>
                                <group>
                                    <field name="total_order_quantity"/>
                                    <field name="total_amount_total"/>
                                </group>
                                <group>
                                    <field name="total_discount_amount"/>
                                </group>
                            </group>
                            <field name="report_line_ids" readonly="1">
                                <tree editable="bottom" limit="1000000">
                                    <field name="family_id"
                                           options="{'no_create': True, 'no_open': True, 'no_edit':True}"/>
                                    <field name="category_id"
                                           options="{'no_create': True, 'no_open': True, 'no_edit':True}"/>
                                    <field name="class_id"
                                           options="{'no_create': True, 'no_open': True, 'no_edit':True}"/>
                                    <field name="brick_id"
                                           options="{'no_create': True, 'no_open': True, 'no_edit':True}"/>
                                    <field name="employee_id"
                                           options="{'no_create': True, 'no_open': True, 'no_edit':True}"/>
                                    <field name="employee_code"/>
                                    <field name="job_position_id"
                                           options="{'no_create': True, 'no_open': True, 'no_edit':True}"/>
                                    <field name="quantity" sum="Quantity"/>
                                    <field name="discount" sum="Discount"/>
                                    <field name="total_amount" sum="Total Amount"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pos_sales_employee_report_line_tree" model="ir.ui.view">
        <field name="name">pos.sales.employee.report.line.tree</field>
        <field name="model">pos.sales.employee.report.line</field>
        <field name="arch" type="xml">
            <tree limit="1000000">
                <field name="family_id"/>
                <field name="category_id"/>
                <field name="class_id"/>
                <field name="brick_id"/>
                <field name="employee_id"/>
                                                    <field name="employee_code"/>
                <field name="job_position_id"/>
                <field name="quantity" sum="Quantity"/>
                <field name="discount" sum="Discount"/>
                <field name="total_amount" sum="Total Amount"/>
            </tree>
        </field>
    </record>
    <record id="view_pos_sales_employee_report_line_pivot" model="ir.ui.view">
        <field name="name">pos.sales.employee.report.line.pivot</field>
        <field name="model">pos.sales.employee.report.line</field>
        <field name="arch" type="xml">
            <pivot string="POS Sales Analysis">
                <field name="family_id" type="row"/>

                <field name="category_id" type="row"/>
                <field name="class_id" type="row"/>
                <field name="brick_id" type="row"/>
                <field name="employee_id" type="col"/>

                <field name="quantity" type="measure"/>
                <field name="discount" type="measure"/>
                <field name="total_amount" type="measure"/>
            </pivot>
        </field>
    </record>
</odoo>