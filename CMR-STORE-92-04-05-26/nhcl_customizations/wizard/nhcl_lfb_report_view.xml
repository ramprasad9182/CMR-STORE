<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="pos_lfb_wise_report" model="ir.ui.view">
        <field name="name">POS LFB Report</field>
        <field name="model">pos.lfb.report.wizard</field>
        <field name="arch" type="xml">
            <form string="POS lfb Summary Report" create="0">
                <h1 style="color:black;text-align:center;">POS LFB Summary Report
                </h1>
                <sheet>
                    <header>
                        <button name="get_last_first_bill_num" string="View LFB Report"
                                type="object"/>
                        <button name="action_lfb_detailed_view" string="View Detailed report"
                                type="object"/>
                        <button special="cancel" string="Cancel"/>
                    </header>
                    <group name="pos_lfb_report" style="border: 2px solid #990099; padding: 10px;">
                        <group>
                            <field name="nhcl_company_id" required="1"
                                   placeholder="Select Company"/>
                        </group>
                        <group>
                            <field name="from_date" required="1"/>
                            <field name="to_date" required="1"/>

                        </group>
                    </group>
                    <notebook>
                        <page string="lfb Lines">
                            <field name="pos_lfb_report_ids" readonly="1" forsesave="1">
                                <tree create="0" delete="0" editable="bottom" limit="1000000">
                                    <field name="nhcl_company_id"/>
                                    <field name="first_bill_no"/>
                                    <field name="Last_bill_no"/>
                                </tree>
                            </field>

                        </page>
                    </notebook>

                </sheet>

            </form>
        </field>
    </record>

    <record id="view_nhcl_pos_lfb_report_tree" model="ir.ui.view">
        <field name="name">pos.lfb.report.line.report.tree</field>
        <field name="model">pos.lfb.report.line</field>
        <field name="arch" type="xml">
            <tree create="0" delete="0" limit="1000000">
                <field name="nhcl_company_id"/>
                <field name="first_bill_no"/>
                <field name="Last_bill_no"/>
            </tree>
        </field>
    </record>
    <record id="view_nhcl_pos_lfb_report_pivot" model="ir.ui.view">
        <field name="name">pos.lfb.report.line.report.pivot</field>
        <field name="model">pos.lfb.report.line</field>
        <field name="arch" type="xml">
            <pivot string="Daily Sale Pivot">
                <field name="nhcl_company_id" type="row"/>
                <field name="first_bill_no" type="row"/>
                <field name="Last_bill_no" type="row"/>
            </pivot>
        </field>
    </record>


    <record id="report_pos_lfb_pdfsss" model="ir.actions.report">
        <field name="name">POS lfb Wise Report</field>
        <field name="model">pos.lfb.report.wizard</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">nhcl_customizations.report_pos_lfb_pdf</field>
        <field name="report_file">nhcl_customizations.report_pos_lfb_pdf</field>
        <field name="binding_type">report</field>
    </record>

</odoo>
