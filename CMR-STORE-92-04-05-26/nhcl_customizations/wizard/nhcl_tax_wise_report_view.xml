<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="pos_tax_wise_report" model="ir.ui.view">
        <field name="name">Store Wise Tax% Report</field>
        <field name="model">pos.tax.report.wizard</field>
        <field name="arch" type="xml">
            <form string="POS tax Summary Report">
                <h1 style="color:black;text-align:center;">POS Tax Wise Report
                </h1>
                <sheet>
                    <header>
                        <button name="get_tax_summery_report" string="View tax Report" type="object"/>
                        <button name="action_summery_tax_detailed_report" string="View Detailed Report" type="object"/>
                        <button special="cancel" string="Cancel"/>
                    </header>
                    <group name="pos_tax_report" style="border: 2px solid #990099; padding: 10px;">
                        <group>
                            <field name="nhcl_company_id" required="1"
                                   placeholder="Select Company"/>
                        </group>
                        <group>
                            <field name="from_date" required="1"/>
                            <field name="to_date" required="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Tax Detailed Report">
                            <group>
                                <group>
                                    <field name="tax_amount"/>
                                    <field name="cgst_amount"/>
                                    <field name="sgst_amount"/>
                                </group>
                                <group>
                                    <field name="tax_amount"/>

                                    <!--                                    <field name="igst_amount"/>-->
                                    <field name="total_tax_amount"/>
                                </group>
                            </group>
                            <field name="pos_tax_report_ids" readonly="1" forsesave="1">
                                <tree create="0" delete="0" editable="bottom" limit="1000000">
                                    <field name="nhcl_company_id"/>
                                    <field name="tax_name"/>
                                    <field name="tax_amount" sum="Total"/>
                                    <field name="cgst_amount" sum="Total"/>
                                    <field name="sgst_amount" sum="Total"/>
                                    <!--                                    <field name="igst_amount" sum="Total"/>-->
                                    <field name="total_tax_amount" sum="Total"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_nhcl_tax_report_line_tree" model="ir.ui.view">
        <field name="name">POS Tax Report Tree</field>
        <field name="model">pos.tax.report.line</field>
        <field name="arch" type="xml">
            <tree>
                <field name="nhcl_company_id"/>
                <field name="tax_name"/>
                <field name="tax_amount" sum="Total"/>
                <field name="cgst_amount" sum="Total"/>
                <field name="sgst_amount" sum="Total"/>
                <!--                                    <field name="igst_amount" sum="Total"/>-->
                <field name="total_tax_amount" sum="Total"/>
            </tree>
        </field>
    </record>
    <record id="view_nhcl_tax_line_pivot" model="ir.ui.view">
        <field name="name">POS Tax Report Tree Pivot</field>
        <field name="model">pos.tax.report.line</field>
        <field name="arch" type="xml">
            <pivot string="POS Tax Analysis">

                <!-- ROW FIELDS (Group By) -->
                <field name="nhcl_company_id" type="row"/>
                <field name="tax_name" type="row"/>
                <!-- MEASURES -->
                <field name="tax_amount" type="measure"/>
                <field name="cgst_amount" type="measure"/>
                <field name="sgst_amount" type="measure"/>
                <field name="total_tax_amount" type="measure"/>
            </pivot>
        </field>
    </record>

</odoo>
