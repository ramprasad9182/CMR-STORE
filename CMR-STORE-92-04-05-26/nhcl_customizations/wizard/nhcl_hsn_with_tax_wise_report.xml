<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="nhcl_hsn_wise_tax_report_form" model="ir.ui.view">
    <field name="name">HSN Wise Tax Report</field>
    <field name="model">nhcl.hsn.tax.report</field>
    <field name="arch" type="xml">
        <form string="HSN Wise Sale Report" create="0">
            <h1 style="color:black;text-align:center;">HSN Wise Sale Report</h1>
            <sheet>
                <header>
                    <button name="get_hsn_with_tax_wise_report" type="object"
                            string="Submit"/>
                    <button name="action_to_reset" type="object"
                            string="Reset"/>
                    <button name="get_excel_sheet" type="object"
                            string="Excel" />
                     <button name="action_view_hsn_tax_lines" type="object"
                            string="View Detailed Report"/>
                </header>
                <group name="hsn_wise_tax" style="border: 2px solid #990099; padding: 10px;">
                    <group name="pos_hour_report_group">
                        <field name="nhcl_company_id" required="1"
                               placeholder="Select Company"/>
                        <field name="l10n_in_hsn_code" widget="l10n_in_hsn_autocomplete"/>
                        <field name="tax_id"/>
                    </group>
                    <group name="hsn_wise_date_details">
                        <group>
                            <field name="from_date" required="1" widget="daterange"
                                   options="{'to_date_field': 'to_date'}"/>
                            <field name="to_date" required="1"/>
                        </group>

                    </group>
                </group>
                <notebook>
                    <page string="HSN Wise Tax Report">
                        <group>
                            <group>
                                <field name="total_order_quantity"/>
                                <field name="total_taxable_amount"/>
                                <field name="total_sgst_amount"/>
                            </group>
                            <group>
                                <field name="total_amount_total"/>
                                <field name="total_cgst_amount"/>
                                <field name="total_tax_amount"/>
                            </group>
                        </group>
                        <field name="nhcl_pos_hsn_tax_ids" readonly="1" forsesave="1">
                            <tree create="0" delete="0" editable="bottom" limit="1000000">
                                <field name="nhcl_company_id"/>
                                <field name="nhcl_hsn"/>
                                <field name="nhcl_tax"/>
                                <field name="nhcl_order_quantity" sum="total_qty"/>
                                <field name="nhcl_amount_total" sum="total_amount"/>
                                <field name="nhcl_taxable_amount" sum="tax_total"/>
                                <field name="nhcl_cgst_amount" sum="cgst_total"/>
                                <field name="nhcl_sgst_amount" sum="sgst_total"/>
                                <field name="nhcl_tax_amount" sum="tax_amount_total"/>
                            </tree>
                        </field>
                    </page>
                </notebook>
            </sheet>
        </form>
    </field>
</record>

     <record id="view_nhcl_hsn_tax_report_line_tree" model="ir.ui.view">
        <field name="name">nhcl.hsn.tax.report.line.tree</field>
        <field name="model">nhcl.hsn.tax.report.line</field>
        <field name="arch" type="xml">
            <tree limit="1000000">
                <field name="nhcl_company_id"/>
                <field name="nhcl_hsn"/>
                <field name="nhcl_tax"/>
                <field name="nhcl_order_quantity" sum="total_qty"/>
                <field name="nhcl_amount_total" sum="total_amount"/>
                <field name="nhcl_taxable_amount" sum="tax_total"/>
                <field name="nhcl_cgst_amount" sum="cgst_total"/>
                <field name="nhcl_sgst_amount" sum="sgst_total"/>
                <field name="nhcl_tax_amount" sum="tax_amount_total"/>
            </tree>
        </field>
    </record>

     <record id="view_nhcl_hsn_tax_report_line_pivot" model="ir.ui.view">
            <field name="name">nhcl.hsn.tax.report.line.pivot</field>
            <field name="model">nhcl.hsn.tax.report.line</field>
            <field name="arch" type="xml">
                <pivot string="HSN TAX Report Analysis">
                    <field name="nhcl_company_id" type="row"/>
                    <field name="nhcl_hsn" type="row"/>
                    <field name="nhcl_amount_total" type="measure"/>
                    <field name="nhcl_taxable_amount" type="measure"/>
                    <field name="nhcl_tax_amount" type="measure"/>
                    <field name="nhcl_cgst_amount" type="measure"/>
                    <field name="nhcl_sgst_amount" type="measure"/>
                    <field name="nhcl_order_quantity" type="measure"/>
                </pivot>
            </field>
        </record>


</odoo>