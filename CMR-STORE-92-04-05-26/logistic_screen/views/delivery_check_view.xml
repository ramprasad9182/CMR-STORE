<odoo>
    <record id="delivery_check_tree" model="ir.ui.view">
        <field name="name">delivery.check.tree</field>
        <field name="model">delivery.check</field>
        <field name="arch" type="xml">
            <tree string="Transport Check" create="0" multi_edit="1">
                <field name="logistic_entry_number" readonly="1"/>
                <field name="logistic_lr_date" readonly="1"/>
                <field name="logistic_lr_number" readonly="1"/>
                <field name="logistic_date" widget="date" optional="show"/>
                <field name="transporter" widget="many2one_avatar_user" readonly="1"/>
                <field name="consignment_number" optional="show"/>
                <field name="po_order_id" readonly="1" optional="show" column_invisible="1"/>
                <field name="state"
                       decoration-success="state == 'delivery'"
                       decoration-info="state == 'draft'"
                       widget="badge"
                       optional="show"/>
                <!--                <field name="no_of_bales" invisible="1"/>-->
                <field name="partial_bales"/>
                <field name="deliver_bales" readonly="1"/>
                <field name="overall_remaining_bales"/>
<!--                <field name="placements"/>-->
                <field name="item_details" optional="show" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="manual_delivery_check_tree" model="ir.ui.view">
        <field name="name">delivery.check.tree</field>
        <field name="model">delivery.check</field>
        <field name="arch" type="xml">
            <tree string="Manual Transport Check" create="1" multi_edit="1">
                <field name="logistic_entry_number" readonly="1"/>
                <field name="logistic_lr_date" readonly="1"/>
                <field name="logistic_lr_number" readonly="1"/>
                <field name="logistic_date" widget="date" optional="show"/>
                <field name="transporter" widget="many2one_avatar_user" readonly="1"/>
                <field name="consignment_number" optional="show"/>
                <field name="po_order_id" readonly="1" optional="show" column_invisible="1"/>
                <field name="state"
                       decoration-success="state == 'delivery'"
                       decoration-info="state == 'draft'"
                       widget="badge"
                       optional="show"/>
                <!--                <field name="no_of_bales" invisible="1"/>-->
                <field name="partial_bales"/>
                <field name="deliver_bales" readonly="1"/>
                <field name="overall_remaining_bales"/>
<!--                <field name="placements"/>-->
                <field name="item_details" optional="show" column_invisible="1"/>
            </tree>
        </field>
    </record>


    <!--    #### Delivery Check Search View #####-->
    <record id="delivery_check_search_view" model="ir.ui.view">
        <field name="model">delivery.check</field>
        <field name="name">delivery.check.search</field>
        <field name="arch" type="xml">
            <search string="Delivery check">
                <field name="transporter"/>
                <field name="po_order_id" invisible="1"/>
                <field name="logistic_entry_number"/>
                <field name="state"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"
                        context="{'default_state': 'draft'}"/>

            </search>
        </field>
    </record>


    <record id="delivery_check_form" model="ir.ui.view">
        <field name="name">delivery.check.form</field>
        <field name="model">delivery.check</field>
        <field name="arch" type="xml">
            <form string="Transport Check" create="0">
                <header>
                    <button name="action_confirm" id="action_confirm" data-hotkey="q"
                            string="Confirm" class="btn-primary" type="object"
                            invisible="state == 'delivery'"/>
                    <button name="print_barcodes" data-hotkey="q"
                            string="Print Barcode Sheet" class="btn-success" type="object"
                            invisible="state == 'draft'"/>
                    <button name="action_duplicate_delivery"
                            string="Duplicate Delivery"
                            type="object"
                            class="btn-secondary"
                            invisible="1"/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,delivery"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_duplicate_records"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-files-o" invisible="duplicate_count == 0">
                            <field name="duplicate_count" widget="statinfo" string="Duplicates"/>
                        </button>
                    </div>
                    <group name="transport_header">
                        <group name="transport_details">
                            <field name="readonly_po_vendor" invisible="1"/>
                            <field name="logistic_entry_number"
                                   placeholder="Enter Logistic Entry Number .." readonly="logistic_entry_number"
                                   force_save="1"/>

                            <field name="transporter"
                                   widget="res_partner_many2one"
                                   placeholder="Type to find a Transporter..." readonly="transporter"
                                   force_save="1"
                                   options="{'no_create': True, 'no_open': True, 'no_edit':True}"
                                   domain="[('group_contact.name','=','Transporter')]"/>

                            <field name="logistic_lr_date"
                                   readonly="logistic_lr_date" force_save="1"/>

                            <field name="logistic_lr_number"
                                   placeholder="Enter Logistic LR Number .." readonly="logistic_lr_number"
                                   force_save="1"/>
                            <field name="invoice_entry"
                                   placeholder="Enter Invoice  Entry.."
                                   readonly="state in ['delivery']"/>
                            <field name="delivery_date"
                                   placeholder="Today Date" readonly="state in ['delivery']"/>
                        </group>
                        <group name="transport_date_details">

                            <field name="logistic_date"
                                   readonly="logistic_date"/>

                            <field name="consignment_number"
                                   placeholder="Enter Consignment Number .."
                                   readonly="consignment_number"/>

                            <field name="po_order_id" readonly="readonly_po_vendor"
                                   options="{'no_create': True, 'no_open': True, 'no_edit':True}" invisible="not po_order_id"/>

                            <field name="no_of_bales"
                                   placeholder="Enter Number Of Bales.."
                                   readonly="no_of_bales"/>

                            <field name="product_id" readonly="product_id"
                                   options="{'no_create': True, 'no_open': True, 'no_edit':True}"/>

                            <field name="city"
                                   placeholder="Enter City.."
                                   readonly="city"/>

                            <field name="item_details" invisible="not po_order_id"/>
                        </group>
                    </group>
                    <p style="font-weight:bold;">Bale Information</p>

                    <hr/>

                    <group>

                        <field name="partial_bales"
                               placeholder="Enter Partial Bales" required="True" readonly="state in ['delivery']"/>
                        <field name="deliver_bales"
                               placeholder="Enter Delivery Bales " required="True" readonly="deliver_bales"
                               force_save="1"/>

                        <field name="overall_remaining_bales"
                               string="Remaining Bales" required="True" readonly="overall_remaining_bales"/>

<!--                        <field name="placements"-->
<!--                               placeholder="Select Zone" required="True" readonly="state in ['delivery']"-->
<!--                               domain="[('name', '!=', 'Basement')]"-->
<!--                               options="{'no_create': True, 'no_open': True, 'no_edit':True}"/>-->
                        <field name="scan_info" force_save="1" invisible="1"
                               readonly="duplicate_count == 1"/>
                        <field name="scan_count" readonly="1" invisible="1" force_save="1"/>

                    </group>
                    <notebook>
                        <page name="Barcodes" string="Barcodes">
                            <field name="delivery_ids">
                                <tree create="false" edit="false" editable="bottom" delete="false">
                                    <field name="serial_no"/>
                                    <field name="delivery_id" options="{'no_open':True}"/>
                                    <field name="barcode"/>
                                    <field name="sequence" readonly="1" force_save="1"/>
                                    <field name="active_receive_bale"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>


    <record id="action_to_delivery_check" model="ir.actions.act_window">
        <field name="name">Delivery Check</field>
        <field name="res_model">delivery.check</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="delivery_check_search_view"/>
        <field name="domain">[('delivery_entry_types', '=', 'automatic')]</field>
        <field name="context">{"search_default_state":'draft' 'create': False}</field>
        <field name="views" eval="[(ref('delivery_check_tree'), 'tree'), (ref('delivery_check_form'), 'form')]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Delivery Check
            </p>
        </field>
    </record>

    <record id="manual_action_to_delivery_check" model="ir.actions.act_window">
        <field name="name">Manual Delivery Check</field>
        <field name="res_model">delivery.check</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="delivery_check_search_view"/>
        <field name="view_id" ref="manual_delivery_check_tree"/>
        <field name="context">{"search_default_state":'draft'}</field>
        <field name="domain">[('delivery_entry_types', '=', 'manual')]</field>
        <!--        <field name="search_view_id" ref="delivery_check_search_view"/>-->
        <!--        <field name="context">{"search_default_state":'draft'}</field>-->

    </record>


    <record id="cmr_dashboard_action" model="ir.actions.client">
        <field name="name">Dashboard</field>
        <field name="tag">cmr_dashboard_tag</field>
    </record>





<!--    <menuitem id="delivery_check_root"-->
<!--              name="Delivery Check"-->
<!--              parent="logistic_menu_entry"-->
<!--              action="action_to_delivery_check"-->
<!--    />-->

    <menuitem id="manual_delivery_check_root"
              name="Delivery Check"
              parent="logistic_menu_entry"
              action="manual_action_to_delivery_check"
    />

</odoo>