<?xml version="1.0" encoding="UTF-8" ?>

<odoo>

    <record id="view_inventory_movement_report_wizard_form" model="ir.ui.view">
        <field name="name">inventory.movement.report.wizard.form</field>
        <field name="model">inventory.movement.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Select Date Range">
                <group>
                    <field name="from_date"/>
                    <field name="to_date"/>
                </group>

                <footer>
                    <button name="action_generate"
                            type="object"
                            string="Generate"
                            class="btn-primary"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>