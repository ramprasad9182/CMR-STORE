<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="pos_lfb_wise_report" model="ir.ui.view">
        <field name="name">POS LFB Report</field>
        <field name="model">pos.lfb.report.wizard</field>
        <field name="arch" type="xml">
            <form string="POS lfb Summary Report" create="0">
                <h1 style="color:black;font-weight:1000;text-align:center;">POS LFB Summary Report
                </h1>
                <sheet>
                    <header>
                        <button name="get_last_first_bill_num" class="btn btn-primary" string="View LFB Report"
                                type="object"/>
                        <button name="get_last_first_bill_num_in_excel" class="btn btn-primary" string="Excel"
                                type="object"/>
                        <button special="cancel" string="Cancel"/>
                    </header>
                <group name="pos_lfb_report" style="border: 2px solid #990099; padding: 10px;">
                    <group>
                        <field name="nhcl_company_id"
                               placeholder="Select Company"/>
                    </group>
                    <group>
                        <field name="from_date" required="1"/>
                        <field name="to_date" required="1"/>

                    </group>
                </group>
                </sheet>

            </form>
        </field>
    </record>


    <record id="report_pos_lfb_pdfsss" model="ir.actions.report">
        <field name="name">POS lfb Wise Report</field>
        <field name="model">pos.lfb.report.wizard</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">nhcl_customizations.report_pos_lfb_pdf</field>
        <field name="report_file">nhcl_customizations.report_pos_lfb_pdf</field>
        <field name="binding_type">report</field>
    </record>

</odoo>
