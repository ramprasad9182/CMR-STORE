<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="multi_vehicle_movement_wizard" model="ir.ui.view">
            <field name="name">multi.vehicle.movement</field>
            <field name="model">multi.vehicle.movement</field>
            <field name="arch" type="xml">
                <form string="Initiate Multi Vehicle Movement">
                    <group>
                        <field name="multi_vehicle_total_qty"/>
                        <field name="reason_code" required="1"/>
                        <field name="remark" required="1"/>
                    </group>
                    <footer>
                        <button class="btn-primary" name="multi_vehicle_movement" string="Submit" type="object"/>
                        <button class="btn-primary" special="cancel" string="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>