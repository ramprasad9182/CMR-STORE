<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="nhcl_pos_sale.SalesPersonsInfoButton" owl="1">
        <button class="control-button btn btn-light rounded-0 fw-bolder"
                    t-on-click="() => this.click()">
            Salesperson
        </button>
    </t>

    <t t-inherit="pos_sale.SetSaleOrderButton" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o_sale_order_button')]" position="attributes">
            <attribute name="class" add="d-none" separator=" "/>
        </xpath>
    </t>

</templates>