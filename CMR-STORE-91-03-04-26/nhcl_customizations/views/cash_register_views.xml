<odoo>

    <record id="view_cash_register_form" model="ir.ui.view">
        <field name="name">cash.register.form</field>
        <field name="model">cash.register</field>
        <field name="arch" type="xml">
            <form string="Cash Register">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,cancel"/>
                    <button name="action_confirm" type="object"
                            string="Confirm" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_cancel" type="object"
                            string="Cancel" invisible="state not in ['draft']"/>
                    <button name="action_reset_to_draft" type="object"
                            string="Reset to Draft" invisible="state != 'cancel'"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_credit_note" type="object" class="oe_stat_button"
                                icon="fa-file-text-o" invisible="credit_note_id ==  False">
                            <field name="credit_note_id" widget="statinfo" string="Credit Note"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date" readonly="state != 'draft'"/>
                            <field name="requester_id" readonly="1"
                                   options='{"no_open": True, "no_create": True,"no_edit": True}'/>
                            <field name="company_id" readonly="1"
                                   options='{"no_open": True, "no_create": True,"no_edit": True}'/>
                            <field name="register_type" readonly="state == 'confirmed'" required="1"/>
                        </group>
                        <group>
                        </group>
                    </group>
                    <notebook>
                        <page string="Details">
                            <button name="nhcl_load_pos_orders" type="object" invisible="state != 'draft'" string="Load Data" class="oe_highlight"/>
                            <field name="line_ids">
                                <tree editable="bottom" create="0" delete="0">
                                    <field name="pos_order_id" column_invisible="parent.register_type != 'cash_register'"
                                           options='{"no_open": True, "no_create": True,"no_edit": True}' readonly="1" force_save="1"/>
                                    <field name="partner_id" readonly="1" force_save="1" column_invisible="parent.register_type != 'cash_register'"
                                           options='{"no_open": True, "no_create": True,"no_edit": True}'/>
                                    <field name="nhcl_select" readonly="parent.state != 'draft'" force_save="1" column_invisible="parent.register_type != 'hsn_code'"/>
                                    <field name="product_template_id" readonly="1" force_save="1" column_invisible="parent.register_type != 'hsn_code'"/>
                                    <field name="product_id" readonly="1" force_save="1" column_invisible="1"/>
                                    <field name="hsn_code" readonly="1" force_save="1" column_invisible="parent.register_type != 'hsn_code'"/>
                                    <field name="quantity" readonly="1" force_save="1" column_invisible="parent.register_type != 'hsn_code'" sum="Quantity"/>
                                    <field name="mobile" readonly="1" force_save="1" column_invisible="parent.register_type != 'cash_register'"/>
                                    <field name="bill_amount" sum="Total Amount" readonly="1" force_save="1"/>
                                    <field name="payment_amount" readonly="1" force_save="1" sum="Payment Amount" column_invisible="parent.register_type != 'cash_register'"/>
                                    <field name="discount" sum="Total Discount" readonly="discount_amount > 0" force_save="1" column_invisible="1"/>
                                    <field name="discount_amount" sum="Total Discount Amount" readonly="discount > 0" force_save="1" column_invisible="parent.register_type != 'hsn_code'"/>
                                    <field name="amount" sum="Amount" readonly="1" force_save="1" column_invisible="parent.register_type != 'hsn_code'"/>
                                </tree>
                            </field>
                            <group name="note_group" col="6" class="mt-2 mt-md-0">
                                <group colspan="4">
                                    <button name="copy_to_register_lines" type="object" invisible="state != 'draft' or register_type != 'hsn_code'" string="Copy to Post" class="oe_highlight"/>
                                </group>
                                <group class="oe_subtotal_footer" colspan="2" name="cash_total">
                                    <field name="total_discount" invisible="register_type != 'cash_register'"/>
                                    <field name="total_amount" colspan="2" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Posting" invisible="register_type != 'hsn_code'">
                            <field name="register_line_ids">
                                <tree editable="bottom" create="0" delete="0">
                                    <field name="product_template_id" options='{"no_open": True, "no_create": True,"no_edit": True}' readonly="1" force_save="1" column_invisible="parent.register_type != 'hsn_code'"/>
                                    <field name="product_id" options='{"no_open": True, "no_create": True,"no_edit": True}' readonly="1" force_save="1" column_invisible="1"/>
                                    <field name="hsn_code" readonly="1" force_save="1" column_invisible="parent.register_type != 'hsn_code'"/>
                                    <field name="amount" sum="Total Amount" readonly="1" force_save="1" column_invisible="parent.register_type != 'hsn_code'"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <record id="view_cash_register_tree" model="ir.ui.view">
        <field name="name">cash.register.tree</field>
        <field name="model">cash.register</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="date"/>
                <field name="requester_id"/>
                <field name="total_amount"/>
                <field name="total_discount"/>
            </tree>
        </field>
    </record>

    <record id="action_cash_register" model="ir.actions.act_window">
        <field name="name">Cash Register</field>
        <field name="res_model">cash.register</field>
        <field name="view_mode">tree,form</field>
    </record>


    <menuitem id="menu_cash_register"
              name="Cash Registers"
              parent="account.menu_finance_receivables"
              action="action_cash_register"
              sequence="10"/>

</odoo>