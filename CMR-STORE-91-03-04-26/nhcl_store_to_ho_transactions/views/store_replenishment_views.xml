<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="nhcl_product_template_form_type" model="ir.ui.view">
        <field name="name">product.template.view.form.inherit.product.type</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='categ_id']" position="after">
                <field name="repl_type"/>
            </xpath>
        </field>
    </record>

    <record id="view_store_replenishment_tree" model="ir.ui.view">
        <field name="name">store.replenishment.tree</field>
        <field name="model">store.replenishment</field>
        <field name="arch" type="xml">
            <tree create="0" delete="0" edit="0">
                <field name="name"/>
                <field name="store_id" options="{'no_create': True, 'no_open': True, 'no_edit':True}"
                               readonly="1" force_save="1"/>
                <field name="product_tmpl_id" options="{'no_create': True, 'no_open': True, 'no_edit':True}" required=""
                               readonly="1" force_save="1"/>
                <field name="repl_type"/>
                <field name="create_date"/>
                <field name="price_from"/>
                <field name="price_to"/>
                <field name="min_qty"/>
                <field name="max_qty"/>
                <field name="onhand_qty"/>
                <field name="differ_qty"/>
                <field name="indent_qty"/>
                <button name="open_form_view" string="Details" class="oe_highlight" type="object"/>
            </tree>
        </field>
    </record>

    <record id="view_store_replenishment_form" model="ir.ui.view">
        <field name="name">store.replenishment.form</field>
        <field name="model">store.replenishment</field>
        <field name="arch" type="xml">
            <form create="0" delete="0" edit="0">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <field name="store_id" options="{'no_create': True, 'no_open': True, 'no_edit':True}"
                               readonly="1" force_save="1"/>
                        <field name="repl_type"/>
                        <field name="product_tmpl_id" options="{'no_create': True, 'no_open': True, 'no_edit':True}"
                               invisible="repl_type != 'regular'" required="repl_type == 'regular'"/>
                        <field name="product_tmpl_ids" options="{'no_create': True, 'no_open': True, 'no_edit':True}" widget="many2many_tags"
                               invisible="1" readonly="repl_type == 'fashion'" force_save="1"/>
                    </group>
                    <notebook>
                        <page string="Replenishment Planning">
                            <field name="line_ids" nolabel="1">
                                <tree editable="bottom" create="0" delete="0" edit="0">
                                    <field name="product_tmpl_id"
                                           options="{'no_create': True, 'no_open': True, 'no_edit':True}"
                                           invisible="parent.repl_type != 'regular'" column_invisible="1"/>
                                    <field name="division"
                                           options="{'no_create': True, 'no_open': True, 'no_edit':True}" column_invisible="0"/>
                                    <field name="price_from"/>
                                    <field name="price_to"/>
                                    <field name="min_qty"/>
                                    <field name="max_qty"/>
                                    <field name="onhand_qty" readonly="1"/>
                                    <field name="differ_qty" readonly="1"/>
                                    <field name="indent_qty"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>



    <!-- Form View -->
    <record id="mbq_division_wizard_view_form" model="ir.ui.view">
        <field name="name">mbq.division.wizard.form</field>
        <field name="model">mbq.division.wizard</field>
        <field name="arch" type="xml">
            <form string="MBQ Division Report">
                <h1 style="color:black;font-weight:1000;text-align:center;">MBQ Report</h1>
                <sheet>
                    <header>
                    <button name="action_generate" type="object" string="Get Info" class="btn-primary"/>
                    <button name="action_export_excel" type="object" string="Export Excel"/>
                    <button name="action_reset" type="object" string="Reset"/>
                </header>
                    <field name="line_ids">
                        <tree editable="bottom" create="0" delete="0" edit="0">
                            <field name="division"/>
                            <field name="onhand_qty"/>
                            <field name="differ_qty"/>
                            <field name="indent_qty"/>
                        </tree>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="division_view_action" model="ir.actions.act_window">
        <field name="name">MBQ Report</field>
        <field name="res_model">mbq.division.wizard</field>
        <field name="view_mode">form</field>
        <field name="context">{'create': False,'edit': False,'delete':False}</field>
    </record>

    <!-- Menu -->
    <menuitem id="division_view_menu"
              name="MBQ Report"
              action="division_view_action"
              parent="stock.menu_warehouse_report"
              groups="group_mbq_notification"
              sequence="60"/>

    <record id="action_store_replenishment" model="ir.actions.act_window">
        <field name="name">MBQ</field>
        <field name="res_model">store.replenishment</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
    </record>

    <menuitem
            id="menu_store_replenishment"
            action="action_store_replenishment"
            name="MBQ"
            parent="stock.menu_stock_procurement"
            sequence="7"/>
</odoo>