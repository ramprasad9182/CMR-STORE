<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="PaymentScreenStatus" t-inherit="point_of_sale.PaymentScreenStatus" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('payment-status-change')]" position="after">
            <div t-if="props.order.get_partner()?.wallet_amount"
                 class="payment-status-total-due py-2 fs-3 text-muted">
                <span class="label pe-2">Wallet Amt.</span>
                <span>
                    ₹ <t t-esc="props.order.get_partner()?.wallet_amount or 0.00" />
                </span>
            </div>
        </xpath>
    </t>
</templates>
