<odoo>
	<record id="view_eway_bill_details_tree" model="ir.ui.view">
		<field name="name">eway.bill.details.tree</field>
		<field name="model">eway.bill.details</field>
		<field name="arch" type="xml">
			<tree>
				<field name="name" optional="show"/>
				<field name="vendor_id" optional="show"/>
				<field name="supply_type" optional="show"/>
				<field name="sub_supply_type" optional="show"/>
				<field name="company_id" optional="show"/>
				<field name="bill_date" optional="show"/>
				<field name="doc_type" optional="show"/>
				<field name="doc_date" optional="show"/>
				<field name="transaction_type" optional="show"/>
			</tree>
		</field>
	</record>

	<record id="view_eway_bill_details_form" model="ir.ui.view">
		<field name="name">eway.bill.details.form</field>
		<field name="model">eway.bill.details</field>
		<field name="arch" type="xml">
			<form string="E-way Bill" class="o_purchase_order">
				<header>
					<button class="oe_highlight" name="generate_eway_bill" string="Generate" type="object"/>
					<button class="oe_highlight" name="generate_consolidated_ewaybill" string="Generate Consolidated" type="object"/>
					<button class="oe_highlight" name="cancel_ewbno" string="Cancel" type="object"/>
					<button class="oe_highlight" name="reject_ewbno" string="Reject" type="object"/>
					<!-- <button class="oe_highlight" name="extend_ewaybill" string="Extend Validity of E-Way Bill" type="object"/> -->
					<button class="oe_highlight" name="regenerate_consolidated_ewaybill" string="Regenerate Consolidated" type="object"/>
					<button class="oe_highlight" name="multi_vehicle_movement" string="Initiate Multi Vehicle Movement" type="object"/>
					<button class="oe_highlight" name="add_multi_vehicle" string="Add Multi Vehicle" type="object"/>
					<button class="oe_highlight" name="get_ewaybill" string="Get E-Way Bill" type="object"/>
					<field name="state" widget="statusbar"/>
				</header>
				<sheet>
					<div class="oe_title">
						<h1 class="d-flex">
							<field name="name" readonly="1"/>
						</h1>
					</div>
					<group>
						<group>
							<field name="vendor_id" widget="res_partner_many2one" context="{'res_partner_search_mode': 'customer', 'show_address': 1, 'show_vat': True}"/>
							<field name="supply_type"/>
							<field name="sub_supply_type"/>
							<field name="company_id" invisible="1" />
						</group>
						<group>
							<field name="bill_date"/>
							<field name="doc_type"/>
							<field name="doc_date"/>
							<field name="transaction_type"/>
							<field name="l10n_in_type_id"/>
						</group>
					</group>
					<notebook>
						<page string="Bill Lines" name="bills">
							<field name="item_ids">
								<tree editable="bottom">
									<field name="sr_no"/>
									<field name="product_id" />
									<field name="name" />
									<field name="product_qty" />
									<field name="product_uom" />
									<field name="price_unit" />
									<field name="tax_ids" widget="many2many_tags"/>
									<field name="price_subtotal" />
								</tree>
							</field>
							<group col="12" class="oe_invoice_lines_tab">
								<group colspan="10">
									<field name="notes" colspan="2" nolabel="1"/>
								</group>
								<group colspan="2">
									<field name="sub_total"/>
									<field name="total_cgst"/>
									<field name="total_sgst"/>
									<field name="total_igst"/>
									<field name="total_cess"/>
									<field name="total_tax" invisible="1"/>
									<field name="grand_total"/>
								</group>
							</group>
						</page>
						<page name="transportation_details" string="Transportation Details">
							<header>
								<button class="oe_highlight" name="update_vehicle_no" string="Update PART-B/Vehicle Number" type="object"/>
								<button class="oe_highlight" name="update_transporter" string="Update Transporter" type="object"/>
							</header>
							<group string="Transportation Details">
								<group>
									<field name="distance"/>
									<field name="transportation_mode"/>
									<field name="transportation_id"/>
									<field name="transportation_gst" readonly="0"/>
								</group>
								<group>
									<field name="document_date"/>
									<field name="document_no"/>
									<field name="vehical_no" readonly="ewb_no"/>
									<field name="vehical_type"/>
								</group>
								<group string="Update PART-B/Vehicle Number Details">
									<group>
										<field name="vehi_date" readonly="1"/>
										<field name="vehi_valid_till" readonly="1"/>
									</group>
								</group>
								<group string="Update Transporter Detail">
									<field name="transporter_ewb_no" readonly="1"/>
									<field name="transportation_gst" readonly="1"/>
									<field name="transporter_date" readonly="1"/>
								</group>
							</group>
						</page>
						<page name="ewaybill_details" string="E-Way Bill Details">
							<header>
								<button class="oe_highlight" name="extend_ewaybill" string="Extend Validity of E-Way Bill" type="object"/>
							</header>
							<group string="E-Way Bill Details">
								<group>
									<!-- QR TEXT -->
									<field name="ewb_no" readonly="1"/>
									<field name="ewb_date" readonly="1"/>
									<field name="ewb_valid_till" readonly="1"/>
								</group>

								<group>
									<!-- QR IMAGE -->
									<field name="qr_code" widget="image"
										options="{'size': [150,150]}"/>
								</group>
							</group>
							<group string="Consolidated E-way Bill Detail" readonly="1">
								<field name="consol_ewb_no"/>
								<field name="consol_ewb_date"/>
							</group>
							<group string="Cancel E-way Bill Detail">
								<field name="cancel_reason" readonly="1"/>
								<field name="cancel_remark" readonly="1"/>
								<field name="cancel_date" readonly="1"/>
							</group>
							<group string="Initiate Multi Vehicle Movement">
								<field name="multi_vehicle_total_qty" readonly="1"/>
								<field name="vehicle_ewb_no" readonly="1"/>
								<field name="group_no" readonly="1"/>
								<field name="created_date" readonly="1"/>
							</group>
						</page>
						<page string="Add Multi Vehicle" name="multi_vehicle">
							<field name="vehicle_line_ids">
								<tree editable="bottom">
									<field name="invoice_id"/>
									<field name="vehicle_no" />
									<field name="group_no" />
									<field name="qty" />
									<field name="vehicle_ewb_no" />
									<field name="created_date" />
									<field name="vehicle_update_date"/>
									<button class="btn-primary" name="change_multi_vehicle" string="Change Multi Vehicle" type="object"/>
								</tree>
							</field>
						</page>
					</notebook>
				</sheet>
			</form>
		</field>
	</record>

	<record id="action_eway_bill_details" model="ir.actions.act_window">
		<field name="name">E-way Bill</field>
		<field name="type">ir.actions.act_window</field>
		<field name="res_model">eway.bill.details</field>
		<field name="view_mode">tree,form</field>
		<field name="context">{}</field>
		<field name="help" type="html">
			<p class="o_view_nocontent_smiling_face">
				create a new E-Way Bill !
			</p>
		</field>
	</record>

	<menuitem id="eway_bill_root" name="E-Way Bill" sequence="0"/>

	<menuitem id="menu_eway_bill" name="E-Way Bill" parent="eway_bill_root" action="action_eway_bill_details" sequence="1"/>
</odoo>